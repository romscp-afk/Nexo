# Supabase — required for auth and database (Sprint 2+)
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production site URL (email confirmation redirects, etc.)
# VITE_SITE_URL=https://nexo-service-sepia.vercel.app

# Optional — enables AI-powered Nexo Assistant (OpenAI)
# VITE_OPENAI_API_KEY=sk-your-openai-key

# WhatsApp OTP (Supabase Edge Function secrets — NOT Vite env)
# For npm run setup:whatsapp-twilio — add Twilio creds here (gitignored), then run the script:
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_OTP_PEPPER=random-long-secret
# Dev mode (OTP on screen): npm run setup:whatsapp-dev

# For npm run deploy:whatsapp-otp — Dashboard → Account → Access Tokens
# SUPABASE_ACCESS_TOKEN=sbp_...

# Optional — for scripts/apply-schema.mjs (Project Settings → Database → password)
# SUPABASE_DB_PASSWORD=your-database-password

# Optional — full connection URI from Dashboard → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
