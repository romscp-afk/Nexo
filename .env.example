# Supabase — required for auth and database (Sprint 2+)
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — enables AI-powered Nexo Assistant (OpenAI)
# VITE_OPENAI_API_KEY=sk-your-openai-key

# WhatsApp OTP (Supabase Edge Function secrets — NOT Vite env)
# Dashboard → Edge Functions → whatsapp-otp → Secrets, or:
#   supabase secrets set TWILIO_ACCOUNT_SID=...
#   supabase secrets set TWILIO_AUTH_TOKEN=...
#   supabase secrets set TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#   supabase secrets set WHATSAPP_OTP_PEPPER=random-long-secret
# Dev without Twilio (shows OTP in API response + server logs):
#   supabase secrets set WHATSAPP_OTP_DEV=true

# Optional — for scripts/apply-schema.mjs (Project Settings → Database → password)
# SUPABASE_DB_PASSWORD=your-database-password

# Optional — full connection URI from Dashboard → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
