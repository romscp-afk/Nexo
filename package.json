{
  "name": "nexo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && test -f dist/index.html",
    "build:gathering": "node scripts/package-gathering.mjs",
    "build:gathering:site": "node scripts/build-gathering.mjs",
    "deploy:vercel": "node scripts/build-gathering.mjs && vercel deploy deploy/silver-legacy-site --prebuilt",
    "dev:gathering": "vite --config vite.gathering.config.ts --open /gathering/",
    "vercel-build": "node scripts/vercel-build.mjs",
    "vercel-install": "node scripts/vercel-install.mjs",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "preview": "vite preview",
    "setup:db": "node scripts/apply-schema.mjs",
    "setup:email-registration": "node scripts/apply-email-registration.mjs",
    "clear:users": "node scripts/clear-users.mjs",
    "setup:site-url": "node scripts/update-supabase-auth-url.mjs",
    "setup:auth-email": "node scripts/setup-auth-email-branding.mjs",
    "setup:phone-verification": "node scripts/apply-phone-verification.mjs",
    "deploy:whatsapp-otp": "node scripts/deploy-whatsapp-otp.mjs",
    "setup:whatsapp-twilio": "node scripts/setup-whatsapp-twilio.mjs",
    "setup:whatsapp-dev": "node scripts/setup-whatsapp-dev.mjs",
    "setup:customer-flow": "node scripts/apply-customer-flow.mjs",
    "setup:booking-chat": "node scripts/apply-booking-chat-rules.mjs",
    "setup:booking-chat-inbox": "node scripts/apply-booking-chat-inbox.mjs",
    "setup:booking-chat-realtime": "node scripts/apply-booking-chat-realtime.mjs",
    "setup:admin-chat-email": "node scripts/apply-admin-chat-email.mjs",
    "deploy:chat-email": "node scripts/deploy-chat-email.mjs",
    "setup:chat-email-resend": "node scripts/setup-chat-email-resend.mjs",
    "setup:provider-availability": "node scripts/apply-provider-availability.mjs",
    "setup:provider-time-off": "node scripts/apply-provider-time-off.mjs",
    "setup:booking-whatsapp": "node scripts/apply-booking-whatsapp-alerts.mjs",
    "deploy:booking-whatsapp": "node scripts/deploy-booking-whatsapp.mjs",
    "setup:pricing": "node scripts/apply-pricing-units.mjs",
    "fix:auth": "node scripts/fix-auth-trigger.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.71.0",
    "pg": "^8.22.0"
  }
}
